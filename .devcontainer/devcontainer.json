{
  "name": "Go",
  "image": "mcr.microsoft.com/devcontainers/go:1.25",
  "runArgs": ["--name", "gosqueal-mgrate"],
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go"
      ]
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y sqlite3 && go mod download"
}
